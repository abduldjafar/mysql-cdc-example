# ================================================================
# Environment Variables — MySQL CDC Stack
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file to version control!
# ================================================================

# Password used for:
#   - MySQL root user
#   - ClickHouse default user
#   - binlog-tap connection
DB_PASSWORD=change_me_use_a_strong_password

# Full MySQL connection URL (used by fintech-data-generator-rs)
DATABASE_URL=mysql://root:change_me_use_a_strong_password@127.0.0.1:3306/fintech_db
