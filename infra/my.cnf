[mysqld]
# ID server harus unik dalam topologi replikasi
server-id         = 1
# Nama prefix untuk file log
log-bin           = mysql-bin
# FORMAT ROW sangat penting untuk CDC agar bisa membaca perubahan data per baris
binlog_format     = ROW
# Menentukan data apa saja yang dicatat di binlog (FULL mencatat data sebelum & sesudah)
binlog_row_image  = FULL
# CRITICAL: Embed column names into binlog events (required for CDC column name resolution)
binlog_row_metadata = FULL

# Retensi log: 7 hari dalam detik (expire_logs_days deprecated sejak MySQL 8.0)
binlog_expire_logs_seconds = 604800
# Batas ukuran per file binlog (mencegah file tunggal terlalu besar)
max_binlog_size   = 512M
# Sinkronisasi binlog ke disk per transaksi — penting untuk CDC correctness
# (0 = lebih cepat tapi risiko kehilangan event jika crash; 1 = aman)
sync_binlog       = 1
